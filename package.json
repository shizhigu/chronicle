{
  "name": "chronicle-monorepo",
  "version": "0.1.0-alpha",
  "description": "Describe any world. Watch AI play it out.",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.1.40",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun x tsc --noEmit",
    "typecheck:per-package": "bun run --filter='*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "changeset:version": "changeset version && bun install",
    "changeset:publish": "bun run build && changeset publish",
    "clean": "rm -rf packages/*/dist packages/*/build .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@changesets/cli": "^2.27",
    "@types/bun": "^1.1",
    "lefthook": "^1.8",
    "typescript": "^5.6"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chronicle-sh/chronicle.git"
  },
  "bugs": {
    "url": "https://github.com/chronicle-sh/chronicle/issues"
  },
  "homepage": "https://chronicle.sh",
  "license": "MIT",
  "author": "Chronicle Contributors"
}
