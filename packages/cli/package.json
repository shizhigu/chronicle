{
  "name": "@chronicle/cli",
  "version": "0.1.0-alpha",
  "description": "Chronicle CLI — natural-language-driven AI simulation framework",
  "type": "module",
  "bin": {
    "chronicle": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "src"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --sourcemap=external --external @chronicle/core --external @chronicle/engine --external @chronicle/runtime --external @chronicle/compiler && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@chronicle/core": "workspace:*",
    "@chronicle/engine": "workspace:*",
    "@chronicle/runtime": "workspace:*",
    "@chronicle/compiler": "workspace:*",
    "commander": "^12",
    "chalk": "^5",
    "ora": "^8",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "^1.1",
    "typescript": "^6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronicle-sh/chronicle.git",
    "directory": "packages/cli"
  },
  "keywords": ["chronicle", "cli", "simulation", "agents", "llm"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
