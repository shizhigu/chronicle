{
  "name": "@chronicle/core",
  "version": "0.1.0-alpha",
  "description": "Core types and primitives for Chronicle",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --sourcemap=external",
    "dev": "bun build src/index.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "nanoid": "^5"
  },
  "devDependencies": {
    "@types/bun": "^1.1",
    "typescript": "^5.6"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronicle-sh/chronicle.git",
    "directory": "packages/core"
  },
  "keywords": ["chronicle", "simulation", "agent", "llm", "core"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
