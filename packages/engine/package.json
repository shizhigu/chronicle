{
  "name": "@chronicle/engine",
  "version": "0.1.0-alpha",
  "description": "Chronicle simulation engine — tick loop, rule enforcement, event log",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --sourcemap=external --external @chronicle/core --external bun:sqlite",
    "dev": "bun build src/index.ts --outdir dist --target bun --format esm --watch --external @chronicle/core --external bun:sqlite",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@chronicle/core": "workspace:*",
    "drizzle-orm": "^0.36"
  },
  "devDependencies": {
    "@types/bun": "^1.1",
    "drizzle-kit": "^0.28",
    "typescript": "^5.6"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronicle-sh/chronicle.git",
    "directory": "packages/engine"
  },
  "keywords": ["chronicle", "simulation", "engine", "event-sourced", "sqlite"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
