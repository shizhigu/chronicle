{
  "name": "@chronicle/compiler",
  "version": "0.1.0-alpha",
  "description": "World and rule compilation from natural language",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --sourcemap=external --external @chronicle/core --external @chronicle/engine",
    "dev": "bun build src/index.ts --outdir dist --target bun --format esm --watch --external @chronicle/core --external @chronicle/engine",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@chronicle/core": "workspace:*",
    "@chronicle/engine": "workspace:*",
    "@mariozechner/pi-ai": "~0.67.3",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "^1.1",
    "typescript": "^6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronicle-sh/chronicle.git",
    "directory": "packages/compiler"
  },
  "keywords": ["chronicle", "compiler", "natural-language", "llm", "zod"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
